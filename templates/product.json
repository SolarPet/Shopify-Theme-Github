show_title":true,"desktop_rating_stars":false,"desktop_show_price":true,"desktop_show_sale_badge":true,"desktop_variant_picker":true,"desktop_full_button_width":false,"desktop_show_price_in_button":false,"desktop_transparent_bg":false,"mobile_show_image":false,"mobile_show_title":true,"mobile_rating_stars":false,"mobile_show_price":true,"mobile_show_sale_badge":true,"mobile_variant_picker":false,"mobile_full_button_width":true,"mobile_show_price_in_button":false,"mobile_transparent_bg":false}},"reviews_8UgFbe":{"type":"reviews","settings":{"color_scheme":"background-1","show_custom_bg":true,"custom_bg_color":"#ededed","corner_radius":12,"border_width":0,"border_color":"#b7b7b7","avatar_alignment":"top","avatar_corner_radius":40,"star_color":"#ffcc00","stars_translate":0,"checkmark_color":"#6d388b","checkmark_icon_color":"#ffffff","slider_type":"slide","autoplay":false,"autoplay_speed":5,"display_arrows":false,"display_dots":true,"author_1":"<em><strong>Recommended By: Dr. Bailey Hills <\/strong><\/em>[checkmark]","image_1":"shopify:\/\/shop_images\/VetPartners_PasMedina_Web-6-scaled.jpg","text_1":"<p>I often recommend red light therapy for pets with joint pain or inflammation. It’s safe, drug-free, and supports the body’s natural healing process. With consistent use, I’ve seen improvements in comfort, mobility, and recovery—especially in older pets.<\/p>","author_2":"<em>Kelly S. <\/em>[stars]","text_2":"","author_3":"Sasha M. [stars]","text_3":"","margin_top":24,"margin_bottom":24}},"collapsible_tab_jgN6Ac":{"type":"collapsible_tab","settings":{"heading":"🔬 Are there studies on red light therapy?","heading_size":"medium","icon":"","filled_icon":false,"collapse_icon":"carret","display_top_border":true,"open":false,"content":"<p>Yes <strong>peer-reviewed veterinary studies<\/strong> show up to <strong>60%+ inflammation reduction<\/strong> and measurable improvements in mobility with consistent use.<br\/>You can review the following studies:<\/p><ul><li>Barale L - Low-Level Laser Therapy for Canine Osteoarthritis <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Barale_L_LLLT_Canine_OA.pdf?v=1677678206\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Barale_L_LLLT_Canine_OA.pdf?v=1677678206\"><strong>Read full study<\/strong><\/a><br\/><\/li><li>Hamblin M - Mechanisms of Low-Level Light Therapy <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Hamblin_M_Mechanisms_of_Low_Level_Light_Therapy.pdf?v=1677678206\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Hamblin_M_Mechanisms_of_Low_Level_Light_Therapy.pdf?v=1677678206\"><strong>Read full study<\/strong><\/a><br\/><\/li><li>Hamblin - Photobiomodulation Therapy: Lasers vs LEDs <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Hamblin_PBMT_Lasers_vs_LEDs.pdf?v=1677678206\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Hamblin_PBMT_Lasers_vs_LEDs.pdf?v=1677678206\"><strong>Read full study<\/strong><\/a><br\/><\/li><li>Looney - Canine Osteoarthritis Treatment <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Looney_Canine_OA.pdf?v=1677678206\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Looney_Canine_OA.pdf?v=1677678206\"><strong>Read full study<\/strong><\/a><br\/><\/li><li>Spitler and Berns - Clinical Application of Photobiomodulation <a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Spitler_and_Berns.pdf?v=1677678206\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0559\/8832\/2374\/files\/Spitler_and_Berns.pdf?v=1677678206\"><strong>Read full study<\/strong><\/a><br\/><\/li><\/ul><p>These studies offer comprehensive evidence supporting the safety and effectiveness of red and infrared light therapy for pets.<\/p>","page":"","margin_top":24,"margin_bottom":0}},"collapsible_tab_AhMFbx":{"type":"collapsible_tab","settings":{"heading":"📏 What is the size? Does it work for pets of All Sizes?","heading_size":"medium","icon":"","filled_icon":false,"collapse_icon":"carret","display_top_border":true,"open":false,"content":"<p><strong>Yes!<\/strong>The SolarPet Red Light Therapy Pad is effective and safe for dogs of <strong>all breeds and sizes<\/strong>, from small breeds like Dachshunds and French Bulldogs to larger breeds like Labradors and German Shepherds. The pad measures <strong>12.7 x 7.1 inches (32 x 18 cm)<\/strong>, providing optimal targeted coverage for your pet's joints, muscles, and affected areas.<\/p>","page":"","margin_top":24,"margin_bottom":0}},"collapsible_tab_9PXGXM":{"type":"collapsible_tab","settings":{"heading":"🔌 Does it need to be plugged in?","heading_size":"medium","icon":"","filled_icon":false,"collapse_icon":"carret","display_top_border":true,"open":false,"content":"<p>Yes, the LumaPet Pad needs power to operate, but it’s designed to be super convenient. You can plug it into a standard wall outlet or use any compatible power bank <strong>i<\/strong>f you prefer cordless sessions.<\/p>","page":"","margin_top":24,"margin_bottom":0}},"collapsible_tab_kaPiEJ":{"type":"collapsible_tab","settings":{"heading":"📦 Shipping & Delivery","heading_size":"medium","icon":"","filled_icon":false,"collapse_icon":"carret","display_top_border":true,"open":false,"content":"<p>On order you will receive tracking details via email, you can then track your order located on the home page. Tracking details may take 1 - 2 working days to be published. For further enquires please contact SolarPetStore1@gmail.com<\/p><p>The estimated lead time on this product is 10 - 12 working days. <br\/><\/p><p>Once your order is confirmed, we carefully prepare and ship your LumaPet promptly. Every package is fully <strong>insured for peace of mind<\/strong>, so you can relax knowing your pet’s new healing companion is on its way.<\/p>","page":"","margin_top":24,"margin_bottom":0}},"collapsible_tab_f8Kbfe":{"type":"collapsible_tab","settings":{"heading":"🔄 Return & Refund Policy","heading_size":"medium","icon":"","filled_icon":false,"collapse_icon":"carret","display_top_border":true,"open":false,"content":"<p>We stand by our product and prioritize customer satisfaction. If you're not completely satisfied with your Luma Pet Red Light Mat, you can return it within 30 days for a full refund. Your furry friend's happiness is our guarantee!<\/p>","page":"","margin_top":24,"margin_bottom":0}}},"block_order":["review_avatars_36eLDb","complementary_EnkdWm","text_qmBJBb","title","description","price_FP7ReB","emoji_benefits_PehqNh","04ba004e-2f54-4936-8b1c-8bcadf6573f6","buy_buttons","icon_with_text_hJHfBk","payment_badges_rgYm7d","e0a0b690-50df-4ca4-acfd-ce2980696cce","e7a28cbe-03cb-4c9d-a2c4-0e3e76ffb3e5","reviews_8UgFbe","collapsible_tab_jgN6Ac","collapsible_tab_AhMFbx","collapsible_tab_9PXGXM","collapsible_tab_kaPiEJ","collapsible_tab_f8Kbfe"],"custom_css":[],"settings":{"display_id":false,"enable_sticky_info":true,"display_variant_image_first":false,"disable_prepend":true,"hide_variants":false,"variant_image_filtering":"none","image_zoom":"none","thumbnails_ratio":"square","arrows_color_scheme":"inverse","transparent_arrows":false,"dots_color_scheme":"inverse","video_player":"play_btn","enable_video_looping":false,"autoplay_videos_pause_btn":false,"video_sound_btn":false,"video_timeline":false,"play_btn_color_scheme":"accent-1","sound_btn_color_scheme":"inverse","timeline_color":"accent-1","media_size":"medium","media_position":"left","gallery_layout":"thumbnail_slider","desktop_thumbnails_position":"bottom","desktop_thumbnails_count":5,"desktop_vertical_thumbnails_width":16,"desktop_vertical_thumbnails_hide_arrows":false,"constrain_to_viewport":true,"media_fit":"contain","desktop_arrows_position":"hidden","mobile_media_corner_radius":0,"mobile_spacing_pixels":0,"mobile_arrows_position":"sides","mobile_pagination":"dots_overlay"