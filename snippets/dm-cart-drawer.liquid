{% comment %} Dropmagic Asset | Version: 1.1.0 {% endcomment %}
<script src='{{ 'dm-cart.js' | asset_url }}' defer='defer'></script>

<script>
  window.shopUrl = '{{ request.origin }}';
  window.routes = {
    cart_add_url: '{{ routes.cart_add_url }}',
    cart_change_url: '{{ routes.cart_change_url }}',
    cart_update_url: '{{ routes.cart_update_url }}',
    cart_url: '{{ routes.cart_url }}',
    predictive_search_url: '{{ routes.predictive_search_url }}'
  };
</script>

{%- if settings.cart_type == 'drawer' -%}
  {{ 'dm-cart.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<style>
    {% if settings.cart_trust_badges != blank %}
      .dm_cart__trust-badges {
        width: {{ settings.cart_trust_badges_width}}%;
        margin: 0 auto;
      }
    {% endif %}


  .dm_drawer {
    visibility: hidden;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    background-color: rgba(var(--neutral-90-rgb), 0.5);
    transition: visibility .2s ease;
    transform: none

  }

  .dm_drawer.active {
    visibility: visible;
  }
</style>

<dm-cart-drawer
  style='{%- if settings.dm_use_other_drawer == true -%}display: none !important; {% endif %} '
  class='dm_drawer{% if cart == empty %} dm-is-empty{% endif %}'
>
  <div id='DM_CartDrawer' class='dm_cart-drawer'>
    <div id='DM_CartDrawer-Overlay' class='dm-cart-drawer__overlay'></div>
    <div
      class='dm_drawer__inner'
      role='dialog'
      aria-modal='true'
      aria-label='{{ settings.cart_title }}'
      tabindex='-1'
    >
      {%- if cart == empty -%}
        <div class='dm-drawer__inner-empty'>
          <div class='dm-cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}'>
            <div class='cart-drawer__empty-content'>
              <div class='cart__empty-emojiWrapper'>
                <p class='cart__empty-emoji'>{{ settings.cart_empty_emoji }}</p>
              </div>
              <h2 class='cart__empty-text'>{{ settings.cart_empty_text }}</h2>
              <button
                class='dm-drawer__close'
                type='button'
                onclick="this.closest('dm-cart-drawer').close()"
                aria-label='{{ 'accessibility.close' | t }}'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  aria-hidden='true'
                  focusable='false'
                  class='icon icon-close'
                  fill='none'
                  viewBox='0 0 18 17'
                >
                  <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
                </svg>
              </button>
              {% if settings.display_continue_shopping %}
                <a
                  href='{% if settings.continue_shopping_url == blank %}{{ routes.all_products_collection_url }}{% else %}{{ settings.continue_shopping_url }}{% endif %}'
                  class='button'
                >
                  {{ settings.cart_continue_shopping_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% else %}
        <div class='dm-drawer__header'>
          <h2 class='dm-drawer__heading'>{{ settings.cart_title }}</h2>
          <button
            class='dm-drawer__close'
            type='button'
            onclick="this.closest('dm-cart-drawer').close()"
            aria-label='{{ 'accessibility.close' | t }}'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              aria-hidden='true'
              focusable='false'
              class='icon icon-close'
              fill='none'
              viewBox='0 0 18 17'
            >
              <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
            </svg>
          </button>
        </div>
        {% if settings.cart_drawer_review_banner_text != blank %}
          <div
            class='dm-cart-review-banner'
            {% unless settings.cart_use_brand_colors %}style='background-color: {{ settings.cart_review_banner_background_color }}; color: {{ settings.cart_review_banner_text_color }};'{% endunless %}
          >
            <p>{{ settings.cart_drawer_review_banner_text }}</p>
          </div>
        {% endif %}
        {% if settings.enable_cart_progress_bar and cart != empty %}
          {% liquid
            assign is_quantity = false
            if settings.cart_progress_goal_type == 'quantity'
              assign is_quantity = true
            endif

            if is_quantity
              assign goal_multiplier = 1.0
              assign goal_max_reference = cart.item_count
            else
              assign goal_multiplier = 100.00
              assign goal_max_reference = cart.items_subtotal_price
            endif

            assign goal = settings.cart_progress_threshold | times: goal_multiplier
            assign goal_progress = goal_max_reference | divided_by: goal | times: 100.0

            assign goal_reached = false
            if goal_progress >= 100.00
              assign goal_reached = true
              assign goal_progress = 100
            endif
          %}

          {% capture goal_difference_html %}
                {% if is_quantity %}
                  {{ goal | minus: cart.item_count | round }}
                {% else %}
                  <span>{{ goal | minus: cart.items_subtotal_price | money_without_trailing_zeros }}</span>
                {% endif %}
              {% endcapture %}

          <div class='cart-progress'>
            <p class='cart-progress__text'>
              {% if goal_reached == false %}
                {{ settings.cart_progress_message | replace: '[amount]', goal_difference_html }}
              {% else %}
                {{ settings.cart_progress_success_message }}
              {% endif %}
            </p>
            <div class='cart-progress__bar'>
              <div class='cart-progress__bar__progress' style='width: {{ goal_progress }}%;'>
                <div class='cart-progress__bar__badge'>
                  {%- unless settings.cart_progress_icon == 'none' -%}
                    {%- if settings.cart_progress_icon != 'none' -%}
                      <span class='svg-wrapper'>{{ settings.cart_progress_icon }}</span>
                    {%- endif -%}
                  {%- endunless -%}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
        <div class='dm-cart-drawer-items-and-upsell'>
          <dm-cart-drawer-items
            {% if cart == empty %}
              class=' dm-is-empty'
            {% endif %}
          >
            <form
              action='{{ routes.cart_url }}'
              id='CartDrawer-Form'
              class='dm_cart__contents dm-cart-drawer__form'
              method='post'
            >
              <div id='DM-CartDrawer-CartItems' class='dm_drawer__contents js-contents'>
                {%- if cart != empty -%}
                  <div class='dm_drawer__cart-items-wrapper'>
                    <table class='cart-items' role='table'>
                      <tbody role='rowgroup'>
                        {%- for item in cart.items -%}
                          <tr
                            id='DM_CartDrawer-Item-{{ item.index | plus: 1 }}'
                            class='cart-item'
                            role='row'
                          >
                            <td
                              class='cart-item__media'
                              role='cell'
                              headers='CartDrawer-ColumnProductImage'
                            >
                              {% if item.image %}
                                {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                                <a
                                  href='{{ item.url }}'
                                  class='cart-item__link'
                                  tabindex='-1'
                                  aria-hidden='true'
                                >
                                </a>
                                <img
                                  class='cart-item__image'
                                  src='{{ item.image | image_url: width: 300 }}'
                                  alt='{{ item.image.alt | escape }}'
                                  loading='lazy'
                                  width='150'
                                  height='{{ 150 | divided_by: item.image.aspect_ratio | ceil }}'
                                >
                              {% endif %}
                            </td>

                            <td
                              class='cart-item__details'
                              role='cell'
                              headers='CartDrawer-ColumnProduct'
                            >
                              {%- if settings.show_vendor -%}
                                <p class='caption-with-letter-spacing light'>
                                  {{ item.product.vendor }}
                                </p>
                              {%- endif -%}

                              <a href='{{ item.url }}' class='cart-item__name clamp-2 h4 break'>
                                {{- item.product.title | escape -}}
                              </a>

                              {% liquid
                                assign display_compare = false
                                assign compare_price = 0
                                for variant in item.product.variants
                                  if variant.id == item.id
                                    assign current_variant = variant
                                  endif
                                endfor

                                if settings.cart_displayed_compare_prices == 'automatic'
                                  if item.original_line_price != item.final_line_price
                                    assign display_compare = true
                                    assign compare_price = item.original_line_price
                                  elsif current_variant.compare_at_price > item.final_price
                                    assign display_compare = true
                                    assign compare_price = current_variant.compare_at_price | times: item.quantity
                                  endif
                                elsif settings.cart_displayed_compare_prices == 'product' and current_variant.compare_at_price > item.final_price
                                  assign display_compare = true
                                  assign compare_price = current_variant.compare_at_price | times: item.quantity
                                elsif item.original_line_price != item.final_line_price
                                  assign display_compare = true
                                  assign compare_price = item.original_line_price
                                endif
                              %}

                              {%- if item.original_price != item.final_price
                                and settings.cart_display_single_item_prices
                              -%}
                                <div class='cart-item__discounted-prices'>
                                  <span class='visually-hidden'>
                                    {{ 'products.product.price.regular_price' | t }}
                                  </span>
                                  <s class='cart-item__old-price product-option'>
                                    {{- compare_price | divided_by: item.quantity | money -}}
                                  </s>
                                  <span class='visually-hidden'>
                                    {{ 'products.product.price.sale_price' | t }}
                                  </span>
                                  <strong class='cart-item__final-price product-option'>
                                    {{ item.final_price | money }}
                                  </strong>
                                </div>
                              {%- endif -%}

                              {%- if item.product.has_only_default_variant == false
                                or item.properties.size != 0
                                or item.selling_plan_allocation != null
                              -%}
                                <dl>
                                  {%- if item.product.has_only_default_variant == false -%}
                                    {% if settings.displayed_variants == 'compact' %}
                                      <div class='product-option'>
                                        {{ item.options_with_values | map: 'value' | join: ' / ' }}
                                      </div>
                                    {% else %}
                                      {%- for option in item.options_with_values -%}
                                        <div class='product-option'>
                                          <dt>{{ option.name }}:</dt>
                                          <dd>
                                            {{ option.value -}}
                                            {%- unless forloop.last %}, {% endunless %}
                                          </dd>
                                        </div>
                                      {%- endfor -%}
                                    {%- endif -%}
                                  {%- endif -%}

                                  {%- for property in item.properties -%}
                                    {%- assign property_first_char = property.first | slice: 0 -%}
                                    {%- if property.last != blank and property_first_char != '_' -%}
                                      <div class='product-option'>
                                        <dt>{{ property.first }}:</dt>
                                        <dd>
                                          {%- if property.last contains '/uploads/' -%}
                                            <a
                                              href='{{ property.last }}'
                                              class='link'
                                              target='_blank'
                                              aria-describedby='a11y-new-window-message'
                                            >
                                              {{ property.last | split: '/' | last }}
                                            </a>
                                          {%- else -%}
                                            {{ property.last }}
                                          {%- endif -%}
                                        </dd>
                                      </div>
                                    {%- endif -%}
                                  {%- endfor -%}
                                </dl>

                                <p class='product-option'>
                                  {{ item.selling_plan_allocation.selling_plan.name }}
                                </p>
                              {%- endif -%}

                              <ul
                                class='discounts list-unstyled'
                                role='list'
                                aria-label='{{ 'customer.order.discount' | t }}'
                              >
                                {%- for discount in item.discounts -%}
                                  <li class='discounts__discount'>
                                    <svg
                                      aria-hidden='true'
                                      focusable='false'
                                      class='icon icon-discount color-foreground-{{ settings.accent_icons }}'
                                      viewBox='0 0 12 12'
                                    >
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z" fill="currentColor">
                                    </svg>

                                    {{ discount.title }}
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </td>

                            <td class='cart-item__right' role='cell' headers='CartDrawer-ColumnTotal'>
                              <!-- REMOVE BUTTON -->
                              <dm-cart-remove-button
                                id='CartDrawer-Remove-{{ item.index | plus: 1 }}'
                                data-index='{{ item.index | plus: 1 }}'
                              >
                                <button
                                  type='button'
                                  class='button button--tertiary cart-item__remove'
                                  aria-label='{{ 'sections.cart.remove_title' | t: title: item.title }}'
                                >
                                  <svg
                                    xmlns='http://www.w3.org/2000/svg'
                                    viewBox='0 0 16 16'
                                    aria-hidden='true'
                                    focusable='false'
                                    class='icon icon-remove'
                                  >
                                    <path d="M14 3h-3.53a3.07 3.07 0 00-.6-1.65C9.44.82 8.8.5 8 .5s-1.44.32-1.87.85A3.06 3.06 0 005.53 3H2a.5.5 0 000 1h1.25v10c0 .28.22.5.5.5h8.5a.5.5 0 00.5-.5V4H14a.5.5 0 000-1zM6.91 1.98c.23-.29.58-.48 1.09-.48s.85.19 1.09.48c.2.24.3.6.36 1.02h-2.9c.05-.42.17-.78.36-1.02zm4.84 11.52h-7.5V4h7.5v9.5z" fill="currentColor"/>
                                    <path d="M6.55 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5zM9.45 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5z" fill="currentColor"/>
                                  </svg>
                                </button>
                              </dm-cart-remove-button>

                              <!-- PRICE SECTION -->
                              <div class='cart-item__price-wrapper'>
                                {% if display_compare %}
                                  <div class='cart-item__discounted-prices'>
                                    <s class='cart-item__old-price price price--end'>
                                      {{ compare_price | money }}
                                    </s>
                                    <span class='price price--end cart-drawer__final-item-price'>
                                      {{ item.final_line_price | money }}
                                    </span>
                                  </div>
                                {% else %}
                                  <span class='price price--end cart-drawer__final-item-price'>
                                    {{ item.original_line_price | money }}
                                  </span>
                                {% endif %}
                              </div>
                            </td>

                            <td
                              class='cart-item__quantity'
                              role='cell'
                              headers='CartDrawer-ColumnQuantity'
                            >
                              <div class='cart-item__quantity-wrapper'>
                                <dm-quantity-input class='quantity cart-quantity'>
                                  <button
                                    class='quantity__button no-js-hidden'
                                    name='minus'
                                    type='button'
                                  >
                                    <span class='visually-hidden'>
                                      {{-
                                        'products.product.quantity.decrease'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <svg
                                      xmlns='http://www.w3.org/2000/svg'
                                      aria-hidden='true'
                                      focusable='false'
                                      class='icon icon-minus'
                                      fill='none'
                                      viewBox='0 0 10 2'
                                    >
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M.5 1C.5.7.7.5 1 .5h8a.5.5 0 110 1H1A.5.5 0 01.5 1z" fill="currentColor">
                                    </svg>
                                  </button>
                                  <input
                                    class='quantity__input'
                                    type='number'
                                    data-quantity-variant-id='{{ item.variant.id }}'
                                    name='updates[]'
                                    value='{{ item.quantity }}'
                                    {% # theme-check-disable %}
                                    data-cart-quantity='{{ cart | item_count_for_variant: item.variant.id }}'
                                    min='{{ item.variant.quantity_rule.min }}'
                                    {% if item.variant.quantity_rule.max != null %}
                                      max='{{ item.variant.quantity_rule.max }}'
                                    {% endif %}
                                    step='{{ item.variant.quantity_rule.increment }}'
                                    {% # theme-check-enable %}
                                    aria-label='{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}'
                                    id='Drawer-quantity-{{ item.index | plus: 1 }}'
                                    data-index='{{ item.index | plus: 1 }}'
                                  >
                                  <button
                                    class='quantity__button no-js-hidden'
                                    name='plus'
                                    type='button'
                                  >
                                    <span class='visually-hidden'>
                                      {{-
                                        'products.product.quantity.increase'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <svg
                                      xmlns='http://www.w3.org/2000/svg'
                                      aria-hidden='true'
                                      focusable='false'
                                      class='icon icon-plus'
                                      fill='none'
                                      viewBox='0 0 10 10'
                                    >
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M1 4.51a.5.5 0 000 1h3.5l.01 3.5a.5.5 0 001-.01V5.5l3.5-.01a.5.5 0 00-.01-1H5.5L5.49.99a.5.5 0 00-1 .01v3.5l-3.5.01H1z" fill="currentColor">
                                    </svg>
                                  </button>
                                </dm-quantity-input>
                              </div>
                            </td>
                          </tr>
                        {%- endfor -%}
                      </tbody>
                    </table>
                  </div>
                {%- endif -%}
                <p id='CartDrawer-LiveRegionText' class='visually-hidden' role='status'></p>
                <p
                  id='DM_CartDrawer-LineItemStatus'
                  class='visually-hidden'
                  aria-hidden='true'
                  role='status'
                >
                  {{ 'accessibility.loading' | t }}
                </p>
              </div>
              <div id='DM_CartDrawer-CartErrors' role='alert'></div>
            </form>
          </dm-cart-drawer-items>
        </div>

        <!-- ----------------- FOOTER ----------------- -->
        <div class='dm_drawer__footer'>
          {%- if settings.show_cart_note -%}
            <details id='Details-CartDrawer'>
              <summary>
                <span class='summary__title'>
                  {{ 'sections.cart.note' | t }}
                  <svg
                    aria-hidden='true'
                    focusable='false'
                    class='icon icon-caret'
                    viewBox='0 0 10 6'
                  >
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
                  </svg>
                </span>
              </summary>
              <dm-cart-note class='cart__note field'>
                <label class='visually-hidden' for='CartDrawer-Note'>
                  {{- 'sections.cart.note' | t -}}
                </label>
                <textarea
                  id='CartDrawer-Note'
                  class='text-area text-area--resize-vertical field__input'
                  name='note'
                  placeholder='{{ 'sections.cart.note' | t }}'
                >{{ cart.note }}</textarea>
              </dm-cart-note>
            </details>
          {%- endif -%}
          <div class='dm-cart-drawer__footer' {{ block.shopify_attributes }}>
            <div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <ul
                  class='discounts list-unstyled'
                  role='list'
                  aria-label='{{ 'customer.order.discount' | t }}'
                >
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <li class='discounts__discount discounts__discount--end'>
                      <svg
                        aria-hidden='true'
                        focusable='false'
                        class='icon icon-discount color-foreground-{{ settings.accent_icons }}'
                        viewBox='0 0 12 12'
                      >
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z" fill="currentColor">
                      </svg>

                      {{ discount.title }}
                      (-{{ discount.total_allocated_amount | money }})
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
            <div class='totals' role='status'>
              <h2 class='totals__subtotal'>{{ settings.cart_subtotal_label -}}</h2>
              <!-- Compare badge -->
              {% assign compare_total = 0 %}
              {% assign real_total = 0 %}

              {% for item in cart.items %}
                {% if item.variant.compare_at_price and item.variant.compare_at_price > 0 %}
                  {% assign price_to_use = item.variant.compare_at_price %}
                {% else %}
                  {% assign price_to_use = item.variant.price %}
                {% endif %}

                {% assign compare_total = compare_total | plus: price_to_use | times: item.quantity %}

                {% assign real_total = real_total | plus: item.final_price | times: item.quantity %}
              {% endfor %}

              {% assign total_savings = compare_total | minus: real_total %}
              <div class='totals__badgeValue'>
                {% if total_savings > 0 %}
                  <p
                    class='cart__savings-badge'
                    {% unless settings.cart_use_brand_colors %}style='background-color: {{ settings.cart_savings_badge_background_color }}; color: {{ settings.cart_savings_badge_text_color }};'{% endunless %}
                  >
                    {{ settings.cart_savings_label -}}
                    {{- total_savings | money_with_currency }}
                  </p>
                {% endif %}

                <p class='totals__subtotal-value'>{{ cart.total_price | money_with_currency }}</p>
              </div>
            </div>
          </div>

          {% if settings.enable_cart_discount %}
            {{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

            <div class='dm-cart-discount'>
              <form class='dm-cart-discount-form' onsubmit='dm_handleDiscountForm(event)'>
                <div class='dm-cart-discount-form__row'>
                  <div class='field'>
                    <input
                      class='field__input'
                      autocomplete='name'
                      type='text'
                      name='cart-discount-field'
                      placeholder='{{ settings.cart_discount_placeholder }}'
                      oninput='dm_handleDiscountFormChange(event)'
                    >
                    {% comment %} <label class="field__label" for="cart-discount-field">{{ settings.cart_discount_placeholder }}</label> {% endcomment %}
                  </div>
                  <button
                    class='button'
                    type='submit'
                    {% unless settings.cart_use_brand_colors %}style='background-color: {{ settings.cart_discount_button_color }}; color: {{ settings.cart_discount_button_text_color }};'{% endunless %}
                  >
                    {{ settings.cart_discount_btn_label }}
                  </button>
                </div>
                <p class='cart-discount-form__error'>Please enter a discount code!</p>
              </form>
            </div>
          {% endif %}

          <!-- CTAs -->

          <div class='dm-cart__ctas' {{ block.shopify_attributes }}>
            <noscript>
              <button
                type='submit'
                class='cart__update-button button button--secondary'
                form='CartDrawer-Form'
              >
                {{ 'sections.cart.update' | t }}
              </button>
            </noscript>

            <button
              type='submit'
              id='DM_CartDrawer-Checkout'
              class='dm_cart__checkout-button button {% if settings.cart_checkout_button_effect == 'shiny' %}shiny{% endif %} shadow-sm'
              name='checkout'
              {% unless settings.cart_use_brand_colors %}style='background-color: {{ settings.cart_checkout_button_color }}; color: {{ settings.cart_checkout_button_text_color }};'{% endunless %}
              form='CartDrawer-Form'
              {% if cart == empty %}
                disabled
              {% endif %}
            >
              {% if settings.cart_checkout_button_show_icon %}
                <svg
                  xmlns:xlink='http://www.w3.org/1999/xlink'
                  xmlns='http://www.w3.org/2000/svg'
                  width='20'
                  height='20'
                  viewBox='0 0 170 233'
                  fill='currentColor'
                  class='checkoutBtnIcon'
                >
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M51.5298 62.2301C51.5298 42.5801 67.4498 26.6501 87.0998 26.6501C106.75 26.6501 122.68 42.5701 122.68 62.2201V94.5101C126.68 93.9201 130.71 93.2201 134.77 92.4101C139.2 91.5501 143.51 90.5801 147.69 89.5401L149.24 89.1401V62.2301C149.29 27.9101 121.52 0.0500778 87.1998 7.77547e-05C55.3298 -0.0499222 28.5898 24.0201 25.2998 55.7201V90.4001L26.6998 90.7301C30.8098 91.6701 35.0798 92.5301 39.4998 93.3201C43.7298 94.0701 47.7098 94.7001 51.4598 95.1901V62.2301H51.5398H51.5298Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M50.73 107.94C46.03 107.34 41.53 106.61 37.31 105.91C33.44 105.23 29.45 104.42 25.35 103.49L23.95 103.17L18.77 101.93L13.6 100.6C13 100.44 12.39 100.36 11.77 100.36C9.32 100.5 7.02 101.59 5.35 103.39C3.05 105.71 1.4 108.6 0.58 111.76C0.2 113.17 0 114.63 0 116.09V217.15C0.01 225.55 6.8 232.37 15.2 232.43H154.26C162.68 232.43 169.51 225.6 169.51 217.18V116.11C169.51 114.65 169.31 113.2 168.93 111.79C168.1 108.63 166.46 105.74 164.16 103.42C162.49 101.62 160.19 100.53 157.74 100.39C157.11 100.39 156.49 100.47 155.88 100.63L153.34 101.29L150.83 101.93L149.28 102.3C145.2 103.29 141.21 104.18 137.32 104.96C132.84 105.84 128.28 106.62 123.67 107.29L122.77 107.42C99.19 110.76 75.26 110.96 51.62 108.03L50.82 107.92H50.73V107.94ZM66.38 150.32C66.38 140.16 74.61 131.93 84.77 131.93C94.93 131.93 103.16 140.16 103.16 150.32C103.16 156.79 99.76 162.79 94.2 166.11L102.25 196.74C102.73 198.5 101.68 200.32 99.92 200.8C99.63 200.88 99.32 200.92 99.02 200.91H70.45C68.62 200.91 67.13 199.43 67.12 197.59C67.12 197.3 67.16 197.01 67.23 196.74L75.28 166.11C69.73 162.79 66.34 156.79 66.36 150.32H66.38Z" fill="currentColor"/>
                </svg>
              {% endif %}
              {{ settings.cart_subtotal_cta -}}
            </button>
          </div>

          {% if settings.show_cart_payment_badges %}
            <div class='dm_cart__badges'>
              <ul class='payment-badges' role='list'>
                {% assign enabled_payment_types = shop.enabled_payment_types %}
                {% if settings.enabled_cart_payment_types != blank %}
                  {% assign enabled_payment_types = settings.enabled_cart_payment_types
                    | remove: ' '
                    | split: ','
                  %}
                {% endif %}

                {%- for type in enabled_payment_types -%}
                  {% assign payment_type = type | strip %}
                  <li class='list-payment__item'>
                    {{ payment_type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {% endif %}
          {% if settings.cart_trust_badges %}
            <div class='dm_cart__badges dm_cart__trust-badges'>
              <img
                src='{{ settings.cart_trust_badges | image_url: width: 800 }}'
                alt='{{ settings.cart_trust_badges.alt | escape }}'
                loading='lazy'
                width='auto'
                height='auto'
              >
            </div>
          {% endif %}
        </div>
      {%- endif -%}
    </div>
  </div>
</dm-cart-drawer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>
